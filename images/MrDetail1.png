Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: https://ajax.googleapis.com/ajax/libs/shaka-player/4.1.2/controls.css

@charset "utf-8";

.shaka-hidden { display: none !important; }

.shaka-video-container { position: relative; top: 0px; left: 0px; display: =
flex; }

.shaka-video-container .material-icons-round { font-family: "Material Icons=
 Round"; font-size: 24px; }

.shaka-video-container * { font-family: Roboto-Regular, Roboto, sans-serif,=
 TengwarTelcontar; }

.shaka-video-container:fullscreen { width: 100%; height: 100%; background-c=
olor: rgb(0, 0, 0); }

.shaka-video-container:fullscreen .shaka-text-container { font-size: 4.4vmi=
n; }

.shaka-video-container:-webkit-full-screen { width: 100%; height: 100%; bac=
kground-color: rgb(0, 0, 0); }

.shaka-video-container:-webkit-full-screen .shaka-text-container { font-siz=
e: 4.4vmin; }

.shaka-controls-container { position: absolute; inset: 0px; margin: 0px; pa=
dding: 0px; width: 100%; height: 100%; box-sizing: border-box; display: fle=
x; flex-direction: column; justify-content: flex-end; align-items: center; =
z-index: 1; }

.shaka-video-container:not([shaka-controls=3D"true"]) .shaka-controls-conta=
iner { display: none; }

.shaka-controls-container * { flex-shrink: 0; }

.shaka-controls-container[casting=3D"true"] .shaka-fullscreen-button { disp=
lay: none; }

.shaka-bottom-controls { width: 96%; padding: 0px 0px 2.5%; z-index: 1; }

.shaka-controls-button-panel { padding: 0px; margin: 0px; display: flex; fl=
ex-direction: row; justify-content: flex-end; align-items: center; overflow=
: hidden; min-width: 48px; font-size: 12px; font-weight: 400; font-style: n=
ormal; user-select: none; opacity: 0; transition: opacity 0.6s cubic-bezier=
(0.4, 0, 0.6, 1); }

.shaka-controls-container[casting=3D"true"] .shaka-controls-button-panel, .=
shaka-controls-container[shown=3D"true"] .shaka-controls-button-panel { opa=
city: 1; }

.shaka-controls-button-panel > * { color: rgb(255, 255, 255); height: 32px;=
 line-height: 0.5; margin: 1px; padding: 0px 5px; background: 0px 0px; bord=
er: 0px; cursor: pointer; }

.shaka-controls-button-panel .shaka-overflow-menu-only { display: none; }

.shaka-play-button-container { margin: 0px; width: 100%; height: 100%; flex=
-shrink: 1; position: absolute; inset: 0px; display: flex; justify-content:=
 center; align-items: center; }

.shaka-statistics-container { overflow: hidden auto; min-width: 300px; colo=
r: rgb(255, 255, 255); background-color: rgba(35, 35, 35, 0.9); font-size: =
14px; padding: 5px 10px; border-radius: 2px; position: absolute; z-index: 2=
; left: 15px; top: 15px; opacity: 0; transition: opacity 0.6s cubic-bezier(=
0.4, 0, 0.6, 1); }

.shaka-controls-container[casting=3D"true"] .shaka-statistics-container, .s=
haka-controls-container[shown=3D"true"] .shaka-statistics-container { opaci=
ty: 1; }

.shaka-statistics-container div { display: flex; justify-content: space-bet=
ween; }

.shaka-statistics-container span { color: rgb(150, 150, 150); }

.shaka-context-menu { background-color: rgba(35, 35, 35, 0.9); border-radiu=
s: 2px; position: absolute; z-index: 3; }

.shaka-context-menu button { padding: 5px 10px; width: 100%; display: flex;=
 align-items: center; color: rgb(255, 255, 255); background: 0px 0px; borde=
r: 0px; cursor: pointer; }

.shaka-context-menu button:hover { background-color: rgba(50, 50, 50, 0.9);=
 }

.shaka-context-menu label { padding: 0px 20px; align-items: flex-start; col=
or: rgb(255, 255, 255); cursor: pointer; }

.shaka-context-menu .shaka-current-selection-span { align-items: flex-start=
; color: rgb(255, 255, 255); cursor: pointer; }

.shaka-scrim-container { margin: 0px; width: 100%; height: 100%; flex-shrin=
k: 1; position: absolute; inset: 0px; opacity: 0; transition: opacity 0.6s =
cubic-bezier(0.4, 0, 0.6, 1); background: linear-gradient(to top, rgb(0, 0,=
 0) 0px, transparent 15%); }

.shaka-controls-container[casting=3D"true"] .shaka-scrim-container, .shaka-=
controls-container[shown=3D"true"] .shaka-scrim-container { opacity: 1; }

.shaka-text-container { position: absolute; inset: 0px; pointer-events: non=
e; width: 100%; min-width: 48px; transition: bottom 0.1s cubic-bezier(0.4, =
0, 0.6, 1) 0.5s; font-size: 20px; line-height: 1.4; color: rgb(255, 255, 25=
5); }

.shaka-text-container span.shaka-text-wrapper { display: inline; background=
: 0px 0px; }

.shaka-controls-container[shown=3D"true"] ~ .shaka-text-container { bottom:=
 15%; transition-delay: 0s; }

.shaka-spinner-container { position: absolute; inset: 0px; width: 100%; hei=
ght: 100%; flex-shrink: 1; display: flex; justify-content: center; align-it=
ems: center; }

.shaka-video-container:not([shaka-controls=3D"true"]) .shaka-spinner-contai=
ner { display: none; }

.shaka-spinner { position: relative; top: 0px; left: 0px; margin: 0px; box-=
sizing: border-box; padding: calc(7.8%); width: 0px; height: 0px; filter: d=
rop-shadow(rgba(255, 255, 255, 0.5) 0px 0px 2px); }

.shaka-play-button { box-sizing: border-box; padding: calc(7.5%); width: 0p=
x; height: 0px; margin: 0px; border-radius: 50%; box-shadow: rgba(0, 0, 0, =
0.1) 0px 0px 20px 0px; border-width: medium; border-style: none; border-col=
or: currentcolor; border-image: initial; background-size: 50%; background-r=
epeat: no-repeat; background-position: center center; background-color: rgb=
a(255, 255, 255, 0.9); opacity: 0; transition: opacity 0.6s cubic-bezier(0.=
4, 0, 0.6, 1); }

.shaka-controls-container[casting=3D"true"] .shaka-play-button, .shaka-cont=
rols-container[shown=3D"true"] .shaka-play-button { opacity: 1; }

.shaka-play-button[icon=3D"play"] { background-image: url("data:image/svg+x=
ml,%3Csvg%20fill%3D%22%23000000%22%20height%3D%2224%22%20viewBox%3D%220%200=
