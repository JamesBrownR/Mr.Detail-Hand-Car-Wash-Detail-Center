@keyframes spinner-container-rotate {=20
  100% { transform: rotate(1turn); }
}

@keyframes spinner-fill-unfill-rotate {=20
  12.5% { transform: rotate(135deg); }
  25% { transform: rotate(270deg); }
  37.5% { transform: rotate(405deg); }
  50% { transform: rotate(540deg); }
  62.5% { transform: rotate(675deg); }
  75% { transform: rotate(810deg); }
  87.5% { transform: rotate(945deg); }
  100% { transform: rotate(3turn); }
}

@keyframes spinner-blue-fade-in-out {=20
  0% { opacity: 0.99; }
  25% { opacity: 0.99; }
  26% { opacity: 0; }
  89% { opacity: 0; }
  90% { opacity: 0.99; }
  100% { opacity: 0.99; }
}

@keyframes spinner-red-fade-in-out {=20
  0% { opacity: 0; }
  15% { opacity: 0; }
  25% { opacity: 0.99; }
  50% { opacity: 0.99; }
  51% { opacity: 0; }
}

@keyframes spinner-yellow-fade-in-out {=20
  0% { opacity: 0; }
  40% { opacity: 0; }
  50% { opacity: 0.99; }
  75% { opacity: 0.99; }
  76% { opacity: 0; }
}

@keyframes spinner-green-fade-in-out {=20
  0% { opacity: 0; }
  65% { opacity: 0; }
  75% { opacity: 0.99; }
  90% { opacity: 0.99; }
  100% { opacity: 0; }
}

@keyframes spinner-left-spin {=20
  0% { transform: rotate(130deg); }
  50% { transform: rotate(-5deg); }
  100% { transform: rotate(130deg); }
}

@keyframes spinner-right-spin {=20
  0% { transform: rotate(-130deg); }
  50% { transform: rotate(5deg); }
  100% { transform: rotate(-130deg); }
}

@keyframes spinner-fade-out {=20
  0% { opacity: 0.99; }
  100% { opacity: 0; }
}

@keyframes quantumWizBoxInkSpread {=20
  0% { transform: translate(-50%, -50%) scale(0.2); }
  100% { transform: translate(-50%, -50%) scale(2.2); }
}

@keyframes quantumWizIconFocusPulse {=20
  0% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
  100% { transform: translate(-50%, -50%) scale(2); opacity: 1; }
}

@keyframes quantumWizRadialInkSpread {=20
  0% { transform: scale(1.5); opacity: 0; }
  100% { transform: scale(2.5); opacity: 1; }
}

@keyframes quantumWizRadialInkFocusPulse {=20
  0% { transform: scale(2); opacity: 0; }
