:root { --amnPwe: #9e9e9e; --ZXiaGf: #202124; --EoKObe: #fff; --cIehld: var=
(--xhUGwc); --ONhrGd: #444746; --gVUKcd: rgba(0,0,0,0.6); --jwFC2e: #213da0=
; --yTtsEf: #c4eed0; }

.zJUuqf { margin-bottom: 4px; }

.AB4Wff { margin-left: 16px; }

@keyframes g-snackbar-show {=20
  0% { pointer-events: none; transform: translateY(0px); }
  100% { transform: translateY(-100%); }
}

@keyframes g-snackbar-hide {=20
  0% { transform: translateY(-100%); }
  100% { transform: translateY(0px); }
}

@keyframes g-snackbar-show-content {=20
  0% { opacity: 0; }
}

@keyframes g-snackbar-hide-content {=20
  100% { opacity: 0; }
}

.LH3wG { bottom: 0px; height: 0px; position: fixed; z-index: 999; }

.yK6jqe { box-sizing: border-box; visibility: hidden; }

.rTYTNb { animation: 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal both run=
ning g-snackbar-hide; visibility: inherit; }

.UewPMd.UewPMd { animation: 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal b=
oth running g-snackbar-show; visibility: inherit; }

.b77HKf { background-color: rgb(60, 64, 67); padding: 0px 24px; }

@media (forced-colors: active) {
  .b77HKf { border: 1px solid canvastext; }
}

.rIxsve { align-items: center; display: flex; }

.rTYTNb .rIxsve { animation: 0.35s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal=
 both running g-snackbar-hide-content; }

.UewPMd .rIxsve { animation: 0.35s cubic-bezier(0.4, 0, 0.2, 1) 0.15s 1 nor=
mal both running g-snackbar-show-content; }

.Txngnb.Txngnb { line-height: 20px; }

.Txngnb { color: rgb(255, 255, 255); flex: 1 1 auto; margin: 14px 0px; word=
-break: break-word; }

@media (min-width: 569px) and (min-height: 569px) {
  .LH3wG { text-align: center; }
  .yK6jqe { display: inline-block; max-width: 568px; min-width: 288px; text=
-align: left; }
  .b77HKf { border-radius: 8px; }
}

.LH3wG { left: 0px; right: 0px; }

.yK6jqe { position: relative; }

.mqsAne { margin-bottom: env(safe-area-inset-bottom); }

sentinel { }
