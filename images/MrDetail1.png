ka-controls-container[shown=3D"true"] .shaka-seek-bar-container { opacity: =
1; }

.shaka-ad-markers { position: absolute; inset: 0px; margin: 0px; padding: 0=
px; width: 100%; height: 100%; }

.shaka-spinner-svg { position: absolute; inset: 0px; animation: 2s linear 0=
s infinite normal none running rotate; transform-origin: center center; wid=
th: 100%; height: 100%; margin: 0px; padding: 0px; }

.shaka-spinner-path { stroke: rgb(32, 33, 36); stroke-dasharray: 20, 200; s=
troke-dashoffset: 0; animation: 1s ease-in-out 0s infinite normal none runn=
ing dash; stroke-linecap: round; }

@keyframes rotate {=20
  100% { transform: rotate(360deg); }
}

@keyframes dash {=20
  0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; }
  50% { stroke-dasharray: 89, 200; stroke-dashoffset: -35px; }
  100% { stroke-dasharray: 89, 200; stroke-dashoffset: -124px; }
}

