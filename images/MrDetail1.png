 background: 0px 0px; color: rgb(0, 0, 0); border-width: medium; border-sty=
le: none; border-color: currentcolor; border-image: initial; min-height: 30=
px; padding: 3.5px 6px; display: flex; align-items: center; cursor: pointer=
; }

