alc(4px) 6px; height: 4px; border-radius: 4px; background: rgb(255, 255, 25=
5); }

.shaka-volume-bar-container { width: 100px; padding: 0px; }

.shaka-range-element { appearance: none; background: 0px 0px; position: abs=
olute; inset: calc(-4px) 0px 0px; margin: 0px; padding: 0px; width: 100%; h=
eight: 12px; z-index: 1; }

